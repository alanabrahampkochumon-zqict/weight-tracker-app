<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="16dp"
    android:paddingEnd="16dp"
    tools:ignore="RtlSymmetry">


    <TextView
        android:id="@+id/tvHistoryItemWeight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_weight"
        android:textAlignment="center"
        android:textColor="@color/slate_800"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHistoryItemDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_date"
        android:textAlignment="textEnd"
        android:textColor="@color/slate_700"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@+id/tvHistoryItemWeight"
        app:layout_constraintTop_toBottomOf="@+id/tvHistoryItemWeight" />

    <ImageButton
        android:id="@+id/btnHistoryItemDelete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/transparent"
        app:tint="@color/red_400"
        android:layout_marginStart="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/tvHistoryItemDate"
        app:layout_constraintStart_toEndOf="@+id/tvHistoryItemWeight"
        app:layout_constraintTop_toTopOf="@+id/tvHistoryItemWeight"
        app:srcCompat="@drawable/delete_icon" />


</androidx.constraintlayout.widget.ConstraintLayout>